TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
OPENAI_API_KEY=your-openai-api-key-here

# Postgres credentials — used by docker-compose for both the db service and to
# construct DATABASE_URL for the bot container. For local dev without Docker,
# set DATABASE_URL directly instead.
POSTGRES_USER=ielts_user
POSTGRES_PASSWORD=changeme
POSTGRES_DB=ielts_bot

# Local dev only (not used by docker-compose)
# DATABASE_URL=postgresql://ielts_user:changeme@localhost:5432/ielts_bot
